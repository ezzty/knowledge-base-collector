# Knowledge Base Collector - Docker Configuration
# Copy this file to .env and edit as needed

# Server port (default: 8396)
KB_PORT=8396

# Where to save Markdown files on your host machine
# Default: ./data/knowledge-base (relative to this directory)
#
# Examples:
#   Linux:   /home/yourname/notes
#   Mac:     /Users/yourname/notes
#   Windows: C:\Users\yourname\Documents\notes
KB_SAVE_PATH=./data/knowledge-base
