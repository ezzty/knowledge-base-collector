# Save Page to Markdown — Docker Configuration
# Copy this file to .env and modify as needed:
#   cp .env.example .env

# Server port (default: 8396)
KB_PORT=8396

# Save path on the host machine (where Markdown files will be stored)
# Default: ./data/knowledge-base (relative to docker/ directory)
# Examples:
#   KB_SAVE_PATH=./data/knowledge-base
#   KB_SAVE_PATH=/home/yourname/notes
#   KB_SAVE_PATH=/mnt/nas/knowledge-base
KB_SAVE_PATH=./data/knowledge-base
